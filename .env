# Twitter API Keys (get from https://developer.twitter.com)
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAA...
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here

# Reddit API Keys (get from https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here

# YouTube API Keys (get from https://console.cloud.google.com)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Instagram API Keys (get from https://developers.facebook.com)
INSTAGRAM_ACCESS_TOKEN=your_instagram_token_here